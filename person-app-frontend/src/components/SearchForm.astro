---
---
<div class="glass rounded-2xl p-8 w-full max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-[#a9b7c6] mb-1 tracking-wide">
    Consulta de Personas
  </h1>
  <p class="text-sm text-[#6a737d] mb-6">
    Ingresá el DNI o cédula para buscar los datos
  </p>

  <form id="search-form" class="flex flex-col gap-4">
    <div class="flex flex-col gap-1">
      <label for="dni-input" class="text-xs font-semibold text-[#6897bb] uppercase tracking-widest">
        DNI / Cédula
      </label>
      <div class="flex gap-2">
        <input
          id="dni-input"
          type="text"
          name="documentNumber"
          placeholder="Ej: 12345678"
          autocomplete="off"
          class="glass-input flex-1 rounded-lg px-4 py-3 text-[#a9b7c6] placeholder-[#6a737d] text-sm font-mono"
        />
        <button
          type="submit"
          class="glass rounded-lg px-5 py-3 text-[#9876aa] border border-[#9876aa]/40 hover:bg-[#9876aa]/20 hover:border-[#9876aa]/70 transition-all duration-200 font-semibold text-sm active:scale-95"
        >
          Buscar
        </button>
      </div>
    </div>
  </form>
</div>
