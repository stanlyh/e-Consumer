---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Consulta de Personas' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="relative overflow-x-hidden">
    <!-- Decorative background blobs -->
    <div class="blob w-96 h-96 top-[-4rem] left-[-6rem]" style="background: #9876aa;"></div>
    <div class="blob w-80 h-80 top-1/3 right-[-5rem]"  style="background: #6897bb;"></div>
    <div class="blob w-64 h-64 bottom-[-3rem] left-1/3" style="background: #6a8759;"></div>

    <main class="relative z-10 min-h-screen flex flex-col">
      <slot />
    </main>
  </body>
</html>
