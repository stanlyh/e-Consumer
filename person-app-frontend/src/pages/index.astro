---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchForm from '../components/SearchForm.astro';
---
<BaseLayout title="Consulta de Personas">
  <div class="flex flex-col items-center justify-center flex-1 px-4 py-16 gap-6">
    <SearchForm />

    <!-- Result area — populated by client-side script -->
    <div id="result-area" class="w-full max-w-md mx-auto"></div>
  </div>
</BaseLayout>

<script>
const API_BASE = 'http://localhost:5152';

const form       = document.getElementById('search-form')   as HTMLFormElement;
const resultArea = document.getElementById('result-area')   as HTMLDivElement;

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const input = (form.elements.namedItem('documentNumber') as HTMLInputElement);
  const dni   = input.value.trim().replace(/\D/g, '');

  if (!dni) {
    showError('Ingresá un número de documento válido.');
    return;
  }

  showLoading();

  try {
    const res = await fetch(`${API_BASE}/api/persons/${encodeURIComponent(dni)}`);

    if (res.status === 404) {
      showNotFound(dni);
      return;
    }

    if (!res.ok) throw new Error(`Error ${res.status}`);

    const person = await res.json();
    showPerson(person, dni);
  } catch (err) {
    showError('No se pudo conectar con el servidor. Verificá que la API esté corriendo.');
  }
});

function showLoading() {
  resultArea.innerHTML = `
    <div class="flex flex-col items-center gap-3 py-8">
      <div class="w-10 h-10 rounded-full border-2 border-[#313335] border-t-[#6897bb] animate-spin"></div>
      <p class="text-sm text-[#6a737d] font-mono">Consultando datos...</p>
    </div>`;
}

function showNotFound(dni: string) {
  resultArea.innerHTML = `
    <div class="glass rounded-2xl px-8 py-6 w-full border border-[#cf5b56]/25" style="background:rgba(49,51,53,0.55);backdrop-filter:blur(20px)">
      <div class="flex items-start gap-3">
        <span class="text-[#cf5b56] text-xl leading-none mt-0.5">✕</span>
        <div>
          <p class="font-semibold text-[#cf5b56] mb-1 text-sm">Sin resultados</p>
          <p class="text-sm text-[#6a737d] font-mono">
            No se encontraron datos para el DNI <strong class="text-[#a9b7c6]">${escHtml(dni)}</strong>.
          </p>
        </div>
      </div>
    </div>`;
}

function showError(msg: string) {
  resultArea.innerHTML = `
    <div class="glass rounded-2xl px-8 py-6 w-full border border-[#bbb529]/25" style="background:rgba(49,51,53,0.55);backdrop-filter:blur(20px)">
      <div class="flex items-start gap-3">
        <span class="text-[#bbb529] text-xl leading-none mt-0.5">⚠</span>
        <p class="text-sm text-[#bbb529] font-mono">${escHtml(msg)}</p>
      </div>
    </div>`;
}

function showPerson(p: any, _dni: string) {
  const formatDate = (iso?: string) =>
    iso ? new Date(iso).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '—';

  const cacheLabel = p.fromCache
    ? `<span class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-1 rounded-full bg-[#6a8759]/20 text-[#6a8759] border border-[#6a8759]/30">
         <span class="w-1.5 h-1.5 rounded-full bg-[#6a8759] inline-block"></span>Desde caché
       </span>`
    : `<span class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-1 rounded-full bg-[#cc7832]/20 text-[#cc7832] border border-[#cc7832]/30">
         <span class="w-1.5 h-1.5 rounded-full bg-[#cc7832] inline-block"></span>Nueva consulta
       </span>`;

  const row = (label: string, value: string, span = false) => `
    <div class="${span ? 'col-span-2' : ''}">
      <p class="text-[10px] font-semibold text-[#6897bb] uppercase tracking-widest mb-0.5">${label}</p>
      <p class="text-sm text-[#a9b7c6] font-mono">${escHtml(value || '—')}</p>
    </div>`;

  resultArea.innerHTML = `
    <div class="glass rounded-2xl overflow-hidden w-full" style="background:rgba(49,51,53,0.55);backdrop-filter:blur(20px);border:1px solid rgba(104,151,187,0.18);box-shadow:0 8px 32px rgba(0,0,0,0.5)">
      <div class="px-8 pt-7 pb-5 border-b border-[#6897bb]/15">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold text-[#6897bb] uppercase tracking-widest mb-1 font-mono">DNI ${escHtml(p.documentNumber)}</p>
            <h2 class="text-xl font-bold text-[#a9b7c6]">${escHtml(p.firstName)} ${escHtml(p.lastName)}</h2>
          </div>
          <div class="shrink-0 mt-1">${cacheLabel}</div>
        </div>
      </div>
      <div class="px-8 py-5">
        <div class="grid grid-cols-2 gap-x-4 gap-y-3">
          ${row('Fecha de nac.', formatDate(p.birthDate))}
          ${row('Edad', p.age != null ? `${p.age} años` : '—')}
          ${row('Dirección', p.address, true)}
          ${row('Localidad', p.locality, true)}
          ${row('Teléfono', p.phone)}
          ${row('Email', p.email)}
        </div>
      </div>
      <div class="px-8 py-3 border-t border-[#6897bb]/10 bg-[#1e1e1e]/30">
        <p class="text-[11px] text-[#6a737d] font-mono">
          Última consulta: <span class="text-[#808080]">${formatDate(p.lastQueriedAt)}</span>
        </p>
      </div>
    </div>`;
}

function escHtml(s: string): string {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}
</script>
